<Project Sdk="Microsoft.NET.Sdk.Worker">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>dotnet-NotificationService-c1f2a6f1-b4d5-4ed7-9ac2-baf848738f5d</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="8.0.1" />
    <!-- Official RabbitMQ Stream-protocol client (NOT the AMQP RabbitMQ.Client). -->
    <PackageReference Include="RabbitMQ.Stream.Client" Version="1.12.0" />
  </ItemGroup>
</Project>
